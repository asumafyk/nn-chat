doctype html 
html(lang="ja")
  head 
    meta(charset = "UTF-8")
    link(rel="stylesheet"
      href="https://cdn.jsdelivr.net/npm/bootstrap@5.3.0/dist/css/bootstrap.min.css"
      integrity="sha256-fx038NkLY4U1TCrBDiu5FWPEa9eiZu01EiLryshJbCo="
      crossorigin="anonymous")
    link(rel="stylesheet", href="style.css")
    link(rel="stylesheet" 
      href="https://cdn.jsdelivr.net/npm/bootstrap-icons@1.8.0/font/bootstrap-icons.css")
    title NNチャット
  body.container(data-bs-theme=currentTheme)
    nav.navbar.fixed-top.bg-primary
      div.container-fluid
        h1.text-light.navbar-brand.mx-auto NNチャットver.2
          i.bi-chat-dots-fill.ms-1
        div.d-flex.align-items-center.gap-2
          button.btn.btn-outline-light(type="button" data-bs-toggle="collapse" data-bs-target="#searchCollapse" aria-expanded="false")
            i.bi-search
        div.drpodown 
          button.btn.btn-outline-light.dropdown-toggle(type="button" id="menu" data-bs-toggle="dropdown" aria-expanded="false") #{user}
            i.bi-gear-fill.ms-1
          ul.dropdown-menu.dropdown-menu-end(aria-labelledby="menu")
            li 
              - const changeThemeText = (currentTheme === 'light' ? 'ダークモードに切り替え' : 'ライトモードに切り替え');
              a.dropdown-item(href="/changeTheme") #{changeThemeText} 
            li
              a.dropdown-item(href="#" id="btn-toggle-size") 文字サイズを大きく
            li
              a.dropdown-item(href="/logout") ログアウト
      //- 折りたたみ式で出てくる検索バー
      div.collapse.w-100#searchCollapse
        div.bg-primary.px-3.pb-1.pt-2.border-top.border-light.border-opacity-25.shadow-sm
          div.input-group
            span.input-group-text.bg-light.border-0.text-secondary
              i.bi-search
            input#search-input.form-control.border-0.bg-light.text-dark(type="text" placeholder="投稿内容やユーザー名を検索...")
    each post in posts
      - const cardClass = (user === post.postedBy ? 'card my-3 border-primary bg-primary-submit' : 'card my-3')
      div(class=cardClass)
        div.card-body 
          div.d-flex.justify-content-between 
            h5.card-title #{post.postedBy}
              if post.postedBy === 'admin'
                i.bi-patch-check-fill.ms-1 
            - const tooltipTitle = `<small>${post.absoluteCreatedAt}</small>`
            small.card-text.float-end(data-bs-toggle="tooltip" data-bs-placement="top" data-bs-html="true" title=tooltipTitle) #{post.relativeCreatedAt}
          p.card-text.lead #{post.content}
        - const isDeletable = (user === post.postedBy || user === "admin")
        if isDeletable 
          div.card-footer.d-flex.justify-content-end
            form(method="post" action="/posts/delete")
              input(type="hidden" name="id" value=post.id)
              input(type="hidden" name="oneTimeToken" value=oneTimeToken)
              button(type="submit").btn.btn-outline-danger.btn-sm 削除
                i.bi-trash
    div.fixed-bottom.p-4.bg-body
      form(method="post" action="/posts" name="message-form").container-fluid.row.g-3
        div.col-12
          textarea(name="content" id="message-textarea" rows="4" placeholder="Ctrl(Command)+Enterで送信できます").form-control
          input(type="hidden" name="oneTimeToken" value=oneTimeToken)
        div.col-12.d-flex.justify-content-between.align-items-center
          //- 文字数カウンター（初期状態は 0 / 140）
          small#char-counter.text-muted 0 / 140
          button(type="submit" id="submit-btn").btn.btn-primary.float-end 送信
            i.bi-send

    script(src="https://cdn.jsdelivr.net/npm/bootstrap@5.3.0/dist/js/bootstrap.bundle.min.js"
      integrity="sha256-qlPVgvl+tZTCpcxYJFdHB/m6mDe84wRr+l81VoYPTgQ="
      crossorigin="anonymous")
    script(src="nn-chat.js")